{
  "manifest_version": 3,
  "name": "LinkList",
  "version": "1.0",
  "description": "Extracts all URLs from selected text and copies them to clipboard",
  "permissions": [
    "activeTab",
    "scripting",
    "contextMenus",
    "clipboardWrite"
  ],
  "background": {
    "service_worker": "linkList.js"
  }
}
